<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
            http://www.liquibase.org/xml/ns/dbchangelog
            https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="002-seed-wallet" author="a.zharov" runOnChange="true">
        <!-- Тестовый кошелек -->
        <insert tableName="wallet">
            <column name="id" value="11111111-1111-1111-1111-111111111111"/>
            <column name="balance" valueNumeric="1000.00"/>
        </insert>

        <rollback>
            <delete tableName="wallet">
                <where>id = '11111111-1111-1111-1111-111111111111'</where>
            </delete>
        </rollback>
    </changeSet>

</databaseChangeLog>